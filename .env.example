# ========== Telegram Bot ==========
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=123456789

# ========== Telegram Local API Server ==========
# Required for sending large files (up to 4GB) via Local API
# Get these from https://my.telegram.org → API development tools
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Local API Server runs on this port (default: 8081)
# Bot connects via this URL (do NOT change the host name)
API_URL=http://localhost:8081

# ========== BBDown ==========
# Path to BBDown binary (default: /usr/local/bin/BBDown in Docker)
BBDOWN_PATH=BBDown

# ========== RSSHub ==========
# Used for subscription polling to bypass Bilibili WBI risk control.
# Option 1: Use the public instance (may be rate-limited or blocked in CN)
#RSSHUB_BASE_URL=https://rsshub.app
#
# Option 2 (recommended): Self-hosted RSSHub via Docker
#   Add the rsshub service to docker-compose.yml and point to it:
RSSHUB_BASE_URL=http://rsshub:1200
#
# Self-hosted one-liner (standalone):
#   docker run -d --name rsshub -p 1200:1200 diygod/rsshub
